# ─── Telegram ───────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here
BOT_USERNAME=your_bot_username

# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/superbot

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── X (Twitter) API ─────────────────────────────────────────
TWITTER_BEARER_TOKEN=your_twitter_bearer_token
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_secret

# ─── Blockchain RPC ──────────────────────────────────────────
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com
ETH_RPC_URL=https://mainnet.infura.io/v3/your_key
ETH_WS_URL=wss://mainnet.infura.io/ws/v3/your_key
BSC_RPC_URL=https://bsc-dataseed.binance.org
BSC_WS_URL=wss://bsc-ws-node.nariox.org:443
BASE_RPC_URL=https://mainnet.base.org
BASE_WS_URL=wss://mainnet.base.org

# ─── Pricing / DEX Data ──────────────────────────────────────
BIRDEYE_API_KEY=your_birdeye_api_key
COINGECKO_API_KEY=your_coingecko_api_key

# ─── Licensing ───────────────────────────────────────────────
PRO_LICENSE_SECRET=your_license_secret_here

# ─── App ─────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
PORT=3000
